# ─────────────────────────────────────────────────────────────────────────────
#  ChannelHelm environment template
#
#  Most of the values below are ALSO editable at /settings (DB-backed, live
#  propagation across processes via pg_notify — no restart). The ones marked
#  [BOOT-ONLY] can ONLY change by editing this file and restarting `pnpm
#  dev:all` — changing them mid-flight breaks running workers.
#
#  See docs/settings.md for the full architecture (DB → process.env
#  hydration + pg_notify LISTEN).
# ─────────────────────────────────────────────────────────────────────────────

# [BOOT-ONLY] Postgres connection string. Drizzle's pool initialises from this
# at process start — cannot be swapped without a restart. Use localhost for a
# single-machine install, or a LAN hostname (e.g. db-host.local) for a fleet.
DATABASE_URL=postgresql://postgres@localhost:5432/channelhelm

# [editable @ /settings] Zernio (external cloud publishing API).
ZERNIO_API_KEY=

# [editable @ /settings] DojoClaw (your local HTTP editorial service on the LAN).
DOJOCLAW_API_URL=http://localhost:8788
DOJOCLAW_API_KEY=

# ─── Webhook signing (REQUIRED before exposing /api/webhooks/* publicly) ─────
# The webhook receivers FAIL CLOSED: a missing secret returns 503 and an
# invalid/absent signature returns 401. Set these before opening the routes
# through the Cloudflare Tunnel.
# [editable @ /settings]
ZERNIO_WEBHOOK_SECRET=
ZERNIO_SIGNATURE_HEADER=x-zernio-signature
# [editable @ /settings]
DOJOCLAW_WEBHOOK_SECRET=
DOJOCLAW_SIGNATURE_HEADER=x-dojoclaw-signature
# [editable @ /settings] Local-only escape hatch: set to 1 to accept UNSIGNED
# webhooks (smoke tests). NEVER set this on a host whose webhook routes are
# publicly reachable.
ALLOW_UNSIGNED_WEBHOOKS=

# ─── LLM providers ──────────────────────────────────────────────────────────
# Providers are configured at runtime in the `llm_providers` table (manage them
# at /providers — OpenAI, Anthropic, OpenRouter, Ollama, LM Studio, OpenClaw,
# Codex CLI). The vars below are ONLY the zero-config fallback: when the table
# is empty, ChannelHelm auto-seeds a single LM Studio provider from these.
# Once you have rows in /providers, these are ignored.
# [Not editable @ /settings — use /providers instead]
OPENCLAW_BASE_URL=http://localhost:18789/v1
LM_STUDIO_DEFAULT_HOST=http://localhost:1234/v1
LM_STUDIO_PREMIUM_HOST=http://localhost:1234/v1
LM_STUDIO_DEFAULT_MODEL=qwen/qwen3-32b
LM_STUDIO_PREMIUM_MODEL=qwen/qwen3-235b-a22b-2507
# Optional: reliable channel-website discovery + richer channel metadata.
YOUTUBE_API_KEY=

# [BOOT-ONLY] Media root for source artifacts + rendered clips. Workers spawn
# ffmpeg/ml subprocesses that resolve paths against this at startup — changing
# it mid-flight desyncs running jobs.
MEDIA_ROOT=/var/channelhelm/media
# [editable @ /settings] Max upload size for POST /api/uploads (bytes; default
# 2 GB).
MAX_UPLOAD_BYTES=2000000000
# [editable @ /settings] Require signed /api/media URLs (set on publicly
# reachable hosts). See §9.4.
MEDIA_REQUIRE_SIGNATURE=
# [editable @ /settings] Secret used to sign /media/* URLs (falls back to
# LOCAL_BEARER_TOKEN).
MEDIA_URL_SECRET=
# [BOOT-ONLY] Secret used to encrypt LLM provider API keys at rest
# (AES-256-GCM). Rotating this mid-flight locks every saved provider key out
# until re-encryption — set once at install, leave alone.
PROVIDER_SECRET_KEY=

# [editable @ /settings] Cloudflare Tunnel public hostname (for Zernio
# webhooks + /media/* URLs).
CLOUDFLARE_TUNNEL_HOSTNAME=

# [editable @ /settings] HuggingFace token for ml/diarize.py — required if you
# want multi-speaker labels. Token must have the
# pyannote/speaker-diarization-3.1 license accepted on huggingface.co.
# transcribe_audio degrades gracefully when unset (mono transcript only).
HF_TOKEN=

# [BOOT-ONLY] Local bearer token for the single-operator API auth. Mid-flight
# rotation invalidates every in-flight worker request — generate via the
# Rotate button on /settings, paste here, then restart `pnpm dev:all`.
LOCAL_BEARER_TOKEN=
