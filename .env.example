# Local Postgres on the M4 Max master.
DATABASE_URL=postgresql://thorsten@m4max.local:5432/channelhelm

# Zernio (external cloud).
ZERNIO_API_KEY=

# DojoClaw (local HTTP service on the LAN).
DOJOCLAW_API_URL=http://m4max.local:8788
DOJOCLAW_API_KEY=

# ─── Webhook signing (REQUIRED before exposing /api/webhooks/* publicly) ─────
# The webhook receivers FAIL CLOSED: a missing secret returns 503 and an
# invalid/absent signature returns 401. Set these before opening the routes
# through the Cloudflare Tunnel.
ZERNIO_WEBHOOK_SECRET=
ZERNIO_SIGNATURE_HEADER=x-zernio-signature
DOJOCLAW_WEBHOOK_SECRET=
DOJOCLAW_SIGNATURE_HEADER=x-dojoclaw-signature
# Local-only escape hatch: set to 1 to accept UNSIGNED webhooks (smoke tests).
# NEVER set this on a host whose webhook routes are publicly reachable.
ALLOW_UNSIGNED_WEBHOOKS=

# ─── LLM providers ──────────────────────────────────────────────────────────
# Providers are configured at runtime in the `llm_providers` table (manage them
# at /providers — OpenAI, Anthropic, OpenRouter, Ollama, LM Studio, OpenClaw).
# The vars below are ONLY the zero-config fallback: when the table is empty,
# ChannelHelm auto-seeds a single LM Studio provider from these. Once you have
# rows in /providers, these are ignored.
OPENCLAW_BASE_URL=http://192.168.0.156:18789/v1
LM_STUDIO_DEFAULT_HOST=http://m4max.local:1234/v1
LM_STUDIO_PREMIUM_HOST=http://m3ultra.local:1234/v1
LM_STUDIO_DEFAULT_MODEL=qwen/qwen3-32b
LM_STUDIO_PREMIUM_MODEL=qwen/qwen3-235b-a22b-2507
# Optional: reliable channel-website discovery + richer channel metadata.
YOUTUBE_API_KEY=

# Media root for source artifacts + rendered clips.
MEDIA_ROOT=/var/channelhelm/media

# Cloudflare Tunnel public hostname (for Zernio webhooks + /media/* URLs).
CLOUDFLARE_TUNNEL_HOSTNAME=

# HuggingFace token for ml/diarize.py — required if you want multi-speaker
# labels. Token must have the pyannote/speaker-diarization-3.1 license
# accepted on huggingface.co. transcribe_audio degrades gracefully when
# unset (mono transcript only).
HF_TOKEN=

# Local bearer token for the single-operator API auth.
LOCAL_BEARER_TOKEN=
