# Drizzle: commit the journal so migrations order is reproducible,
# ignore per-migration snapshot caches (regenerated by `drizzle-kit generate`).
migrations/meta/*.json
!migrations/meta/_journal.json

# Logs / tmp
*.log
tmp/
.cache/
