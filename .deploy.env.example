# Copy to .deploy.env (gitignored) and fill in your all-inkl FTP details.
# Used by `pnpm deploy:marketing` to publish public/*.html to channelhelm.com.
FTP_HOST=wXXXXXXX.kasserver.com
FTP_USER=fXXXXXXX
FTP_PASS='your-ftp-password'
# Remote directory the FTP user lands in / should write to.
FTP_PATH=/ChannelHelm.com/
